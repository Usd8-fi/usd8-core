pragma solidity 0.8.28;

import {Script} from "forge-std/Script.sol";
import {USD8} from "../src/USD8.sol";

contract USD8Script is Script {
    function run() external {
        vm.broadcast();
        new USD8(vm.envAddress("USD8_TREASURY"));
    }
}
